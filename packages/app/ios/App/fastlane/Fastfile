default_platform(:ios)

platform :ios do
  private_lane :asc_api_key do
    key_id = ENV["ASC_KEY_ID"]&.strip
    issuer_id = ENV["ASC_ISSUER_ID"]&.strip
    key_content = ENV["ASC_KEY_CONTENT"]&.strip
    key_path = ENV["ASC_KEY_PATH"]&.strip
    expanded_key_path = key_path.to_s.empty? ? "" : File.expand_path(key_path)

    missing = []
    missing << "ASC_KEY_ID" if key_id.to_s.empty?
    missing << "ASC_ISSUER_ID" if issuer_id.to_s.empty?

    if key_content.to_s.empty? && key_path.to_s.empty?
      missing << "ASC_KEY_CONTENT (base64) or ASC_KEY_PATH (.p8 path)"
    end

    unless missing.empty?
      UI.user_error!("Missing required App Store Connect credentials: #{missing.join(', ')}")
    end

    if !expanded_key_path.empty? && !File.exist?(expanded_key_path)
      UI.user_error!("ASC_KEY_PATH does not exist: #{expanded_key_path}")
    end

    params = {
      key_id: key_id,
      issuer_id: issuer_id
    }

    if !key_content.to_s.empty?
      params[:key_content] = key_content
      params[:is_key_content_base64] = true
    else
      params[:key_filepath] = expanded_key_path
    end

    app_store_connect_api_key(**params)
  end

  private_lane :asc_app_identifier do
    ENV.fetch("APP_IDENTIFIER", "com.ottegi.sequenced-app")
  end

  private_lane :build_changelog do
    notes = ENV["ASC_CHANGELOG"].to_s.strip
    if notes.empty?
      last_tag = `git describe --tags --abbrev=0 2>/dev/null`.strip
      range = last_tag.empty? ? "-15" : "#{last_tag}..HEAD"
      notes = `git log #{range} --pretty=format:"• %s" --no-merges`.strip
      notes = "Bug fixes and improvements." if notes.empty?
    end
    notes
  end

  private_lane :next_build_for_current_version do |options|
    api_key = options[:api_key]
    app_identifier = options[:app_identifier]

    # Read version from package.json so it's always the source of truth,
    # then stamp it into the Xcode project (in case cap sync reset it).
    pkg_version = JSON.parse(File.read(File.expand_path("../../../package.json", __dir__)))["version"]
    increment_version_number(
      version_number: pkg_version,
      xcodeproj: "App.xcodeproj"
    )

    version = get_version_number(
      xcodeproj: "App.xcodeproj",
      target: "App"
    )

    latest_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: app_identifier,
      version: version,
      initial_build_number: 0
    )

    {
      version: version,
      next_build: latest_build.to_i + 1
    }
  end

  desc "Build and upload to App Store Connect with auto-incremented build number per marketing version"
  lane :upload_app_store_connect do
    api_key = asc_api_key
    app_identifier = asc_app_identifier
    version_build = next_build_for_current_version(
      api_key: api_key,
      app_identifier: app_identifier
    )
    version = version_build[:version]
    next_build = version_build[:next_build]

    UI.message("Preparing #{app_identifier} version #{version} build #{next_build}")

    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: next_build.to_s
    )

    build_ios_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      destination: "generic/platform=iOS",
      sdk: "iphoneos"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_identifier,
      changelog: ENV["ASC_CHANGELOG"],
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      notify_external_testers: false
    )
  end

  desc "Build, upload, wait for processing, then submit the new build for App Review"
  lane :release_app_store do
    setup_ci if is_ci
    api_key = asc_api_key
    app_identifier = asc_app_identifier
    version_build = next_build_for_current_version(
      api_key: api_key,
      app_identifier: app_identifier
    )
    version = version_build[:version]
    next_build = version_build[:next_build]

    UI.message("Preparing release #{app_identifier} version #{version} build #{next_build}")

    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: next_build.to_s
    )

    build_ios_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      destination: "generic/platform=iOS",
      sdk: "iphoneos"
    )

    upload_to_testflight(
      api_key: api_key,
      app_identifier: app_identifier,
      changelog: ENV["ASC_CHANGELOG"],
      skip_waiting_for_build_processing: false,
      distribute_external: false,
      notify_external_testers: false
    )

    changelog = build_changelog

    upload_to_app_store(
      api_key: api_key,
      app_identifier: app_identifier,
      app_version: version,
      build_number: next_build.to_s,
      skip_metadata: false,
      release_notes: { "en-US" => changelog },
      skip_screenshots: true,
      skip_binary_upload: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end
end
