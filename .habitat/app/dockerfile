# ---------- deps ----------
FROM node:22-alpine AS deps
WORKDIR /app

# copy root and any workspace manifests
COPY package.json package-lock.json ./
COPY packages/app/package*.json ./packages/app/
COPY packages/api/package*.json ./packages/api/

# install dependencies
RUN npm ci --workspaces

# ---------- build ----------
FROM node:22-alpine AS build
WORKDIR /app

# reuse installed dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/package.json ./package.json
COPY --from=deps /app/packages/app/package.json ./packages/app/package.json
COPY packages/app/src ./packages/app/src
COPY packages/app/public ./packages/app/public
COPY packages/app/index.html ./packages/app/index.html
COPY packages/app/.env ./packages/app/.env
COPY packages/app/vite.config.ts ./packages/app/vite.config.ts
COPY packages/app/tsconfig.json ./packages/app/tsconfig.json
COPY packages/app/eslint.config.js ./packages/app/eslint.config.js
COPY packages/app/capacitor.config.ts ./packages/app/capacitor.config.ts

# configure environment variables
ENV NODE_ENV=production

# build the project workspace
RUN npm run build --workspace=app

# ---------- runtime ----------
FROM node:22-alpine AS runtime
WORKDIR /app

# configure environment variables
ENV NODE_ENV=production

# copy only what is needed at runtime
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/app/package.json ./package.json
COPY --from=build /app/packages/app/dist ./dist
COPY --from=build /app/packages/app/public ./public

EXPOSE 3000
CMD ["npm","run","sync"]