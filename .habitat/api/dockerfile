# ---------- deps ----------
FROM node:22-alpine AS deps
WORKDIR /app

# copy root and any workspace manifests
COPY package.json package-lock.json ./
COPY packages/app/package*.json ./packages/app/
COPY packages/api/package*.json ./packages/api/

# install dependencies
RUN npm ci --workspaces

# ---------- build ----------
FROM node:22-alpine AS build
WORKDIR /app

# reuse installed dependencies
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/package.json ./package.json
COPY --from=deps /app/packages/api/package.json ./packages/api/package.json
COPY packages/api/src ./packages/api/src
COPY packages/api/.env ./packages/api/.env
COPY packages/api/tsconfig.json ./packages/api/tsconfig.json
COPY packages/api/eslint.config.js ./packages/api/eslint.config.js

# configure environment variables
ENV NODE_ENV=production

# build the project workspace
RUN npm run build --workspace=api

# ---------- runtime ----------
FROM node:22-alpine AS runtime
WORKDIR /app

# configure environment variables
ENV NODE_ENV=production

# copy only what is needed at runtime
COPY --from=deps /app/node_modules ./node_modules
COPY --from=deps /app/packages/api/package.json ./package.json
COPY --from=build /app/packages/api/dist ./dist

EXPOSE 3001
CMD ["npm","run","start"]